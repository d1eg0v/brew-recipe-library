// Prisma schema for the Brew Recipe Library.
// Docs: https://pris.ly/d/prisma-schema
//
// Notes on conventions:
// - All physical quantities are stored in metric SI units (kg, litres, grams,
//   Celsius). Imperial display/conversion happens in app code, never in the DB.
// - SQLite does not support Prisma enums, so categorical fields (fermentable
//   type, hop use, mash step type, etc.) are stored as String with the
//   documented allowed values noted inline.
// - The library covers beer, mead, wine, cider, and other home ferments. Beer
//   is the fully-specified path; non-beer recipes simply leave beer-only lists
//   (hops, mashSteps) empty and use the generic ProcessStep / Addition models.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A brewing recipe: metadata, style targets, and its ingredient/process lists.
model Recipe {
  id          String  @id @default(cuid())
  title       String
  author      String?
  description String?
  notes       String?

  // What kind of ferment this is. `category` remains the app-facing field for
  // backwards compatibility; `beverageType` is the FermentDB schema flag.
  category String @default("beer") // beer | mead | wine | cider | other
  beverageType String @default("beer") @map("beverage_type") // beer | mead | wine | cider | other

  // Style / classification
  styleName    String? // e.g. "American IPA", "Traditional Mead", "Country Wine"
  bjcpCategory String? // e.g. "21A" (BJCP beer code; also used for mead/cider style codes where they exist)

  // Batch parameters (metric)
  batchSizeLiters Float @default(20)
  boilTimeMinutes Int   @default(60) // beer/boiled recipes; 0 for no-boil mead/wine kits
  efficiencyPct   Float @default(75) // brewhouse efficiency; grain-based recipes only

  // Target measurements
  targetOg  Float? // original gravity, e.g. 1.056
  targetFg  Float? // final gravity, e.g. 1.012
  targetPh  Float? @map("target_ph") // target acidity; useful for mead/wine/cider
  targetAbv Float? // % alcohol by volume
  targetIbu Float? // International Bitterness Units (beer only; null for mead/wine)
  targetSrm Float? // colour (Standard Reference Method) (beer only; null for mead/wine)

  fermentables Fermentable[]
  hops         Hop[] // beer/cider hopping; empty for mead & most wine
  yeasts       Yeast[]
  mashSteps    MashStep[] // grain-based recipes only; empty for mead & extract/juice recipes
  processSteps ProcessStep[] // generic fermentation/racking/backsweetening steps (all categories)
  additions    Addition[] // nutrients, acid blend, campden, pectic enzyme, etc.
  batches      Batch[] // logged actual brews of this recipe (brew-day history)
  batchLogs    BatchLog[] // flexible FermentDB timeline events across active batches
  recipeTags   RecipeTag[] // freeform labels (BRE-29); join through Tag

  // BRE-43: opaque, unguessable URL token for the public read-only share link.
  // null = not currently shareable; setting it issues a /share/[token] URL and
  // clearing it revokes the URL. Unique so two recipes can never collide on
  // the same token.
  shareToken   String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([styleName])
  @@index([bjcpCategory])
}

/// Freeform label for a recipe ("session", "competition", "summer", ...).
/// Independent of the fixed `Recipe.category`. Names are stored normalised
/// (trimmed, lower-case) so equality and uniqueness are case-insensitive at the
/// application layer. A recipe can have many tags; a tag can be applied to many
/// recipes — the join table is `RecipeTag` (BRE-29).
model Tag {
  id        String   @id @default(cuid())
  /// Normalised tag name. Always trimmed + lower-case on write. The DB unique
  /// constraint prevents duplicates; the UI surfaces the original casing.
  name      String   @unique
  createdAt DateTime @default(now())

  recipeTags RecipeTag[]
}

/// Many-to-many join between `Recipe` and `Tag`. Cascade-deletes with either
/// parent so we never leave orphan rows.
model RecipeTag {
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  tag      Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId    String

  createdAt DateTime @default(now())

  @@id([recipeId, tagId])
  @@index([tagId])
}

/// A fermentable sugar source contributing gravity and (for beer) colour.
/// Covers grain/extract/sugar (beer), honey (mead), and juice/must/concentrate/
/// fruit (wine, cider, melomels). Solids use amountKg; liquids (juice/must) may
/// instead use amountLiters — at least one of the two should be set.
model Fermentable {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name          String
  // grain | extract | sugar | adjunct | honey | juice | concentrate | fruit | must
  type          String  @default("grain")
  amountKg      Float? // mass for solids (grain, honey, sugar, fruit); null if liquid-only
  amountLiters  Float? // volume for liquid fermentables (grape juice/must/concentrate)
  colorLovibond Float? // grain colour (°L); beer only
  potentialPpg  Float? // gravity potential, points per pound per gallon
  notes         String?
  position      Int     @default(0) // display order within the fermentable list

  @@index([recipeId])
}

/// A hop addition in the boil / whirlpool / dry-hop schedule.
model Hop {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name         String
  amountGrams  Float
  alphaAcidPct Float? // % alpha acids, used for IBU math
  timeMinutes  Int     @default(60) // contact time; boil minutes or dry-hop days
  use          String  @default("boil") // boil | firstWort | whirlpool | dryHop | mash
  form         String  @default("pellet") // pellet | leaf | plug | extract
  notes        String?
  position     Int     @default(0)

  @@index([recipeId])
}

/// A yeast (or other fermentation microbe) used to attenuate the wort.
model Yeast {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name            String
  laboratory      String? // e.g. "Wyeast", "White Labs", "Fermentis"
  productId       String? // e.g. "US-05", "1056"
  type            String  @default("ale") // ale | lager | wheat | wine | champagne | other
  form            String  @default("dry") // dry | liquid | slant | culture
  attenuationPct  Float? // apparent attenuation %
  abvTolerancePct Float? // maximum alcohol tolerance for mead/wine/cider strains
  temperatureCMin Float?
  temperatureCMax Float?
  notes           String?
  position        Int     @default(0)

  @@index([recipeId])
}

/// A single step in the mash schedule (infusion / rest / decoction).
model MashStep {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name               String
  type               String  @default("infusion") // infusion | temperature | decoction
  stepTempC          Float
  stepTimeMinutes    Int     @default(60)
  infuseAmountLiters Float?
  notes              String?
  position           Int     @default(0) // ordered sequence of steps

  @@index([recipeId])
}

/// A generic process/fermentation step that applies across all categories
/// (beer, mead, wine, cider). Covers primary/secondary fermentation, racking,
/// backsweetening, stabilizing, aging, bottling — anything that is not a mash.
model ProcessStep {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name         String // e.g. "Primary fermentation", "Rack to secondary", "Backsweeten"
  // primary | secondary | racking | backsweetening | stabilizing | aging | bottling | other
  type         String  @default("other")
  tempC        Float? // target temperature for the step, if controlled
  durationDays Float? // typical duration in days (fractional allowed)
  notes        String?
  position     Int     @default(0) // ordered sequence of steps

  @@index([recipeId])
}

/// A non-fermentable, non-hop, non-yeast addition: yeast nutrient, acid blend,
/// pectic enzyme, campden / potassium metabisulfite, tannin, finings, etc.
/// Common in mead and wine; occasionally used in beer.
model Addition {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  name     String // e.g. "Fermaid-O", "Acid blend", "Campden tablet", "Pectic enzyme"
  amount   Float? // numeric quantity, paired with unit
  unit     String? // g | ml | tsp | tablet | ppm | etc. (free text; no fixed metric)
  purpose  String? // e.g. "yeast nutrient", "acidity adjustment", "sanitation/antioxidant"
  timing   String? // e.g. "at pitch", "at racking", "24h before pitch", "at bottling"
  notes    String?
  position Int     @default(0)

  @@index([recipeId])
}

/// A logged actual brew of a recipe: the brew-day record with measured values,
/// as opposed to the recipe's planned targets. One recipe can have many batches
/// (each time it's brewed). Achieved ABV / efficiency / attenuation are derived
/// from these measurements in app code (see src/lib/brewing/batch.ts), never
/// stored redundantly. All physical quantities stay in metric SI units.
model Batch {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  brewDate     DateTime // when the batch was brewed
  measuredOg   Float? // original gravity read on brew day (e.g. 1.054)
  measuredFg   Float? // final gravity read at the end of fermentation
  volumeLiters Float? // volume into the fermenter (used for achieved-efficiency math)
  notes        String? // brew-day notes and any deviations from the recipe

  logs BatchLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
}

/// On-hand pantry inventory of brewing ingredients (BRE-40). Used to cross-
/// reference the recipe shopping list and surface what still needs buying.
/// Keyed on (category, normalisedName, normalisedDetail, normalisedUnit) so the
/// UI can match one inventory row to one shopping-list row — the same
/// name+detail+unit rules the shopping-list builder uses to bucket ingredients.
model InventoryItem {
  id String @id @default(cuid())

  // fermentable | hop | yeast | addition
  category        String
  /// Display name as the brewer typed it. The canonical matching key is the
  /// lower-cased trimmed value, stored separately to keep the unique index
  /// case-insensitive without sacrificing the original casing in the UI.
  name            String
  /// Lower-cased trimmed name. Used for equality + unique index.
  nameNormalized  String
  /// Sub-bucket key matching the shopping-list `detail` field: hop use
  /// ("boil", "dryHop"), yeast form ("dry", "liquid"), addition unit ("tsp"),
  /// or "" for fermentables / un-sub-bucketed rows.
  detail          String  @default("")
  /// Lower-cased trimmed detail. Used for equality + unique index.
  detailNormalized String @default("")
  /// Display unit ("kg", "g", "L", "packets", "tsp", "tablet", …). Matches the
  /// shopping-list row's `unit` for direct cross-reference.
  unit            String  @default("")
  /// Lower-cased trimmed unit. Used for equality + unique index.
  unitNormalized  String  @default("")
  /// Quantity on hand in `unit`. Stored as metric / canonical quantity for
  /// metric units (kg, g, L) and as the same scale for free-text units
  /// (e.g. packets, tsp) — there is no implicit imperial conversion in the DB.
  amountOnHand    Float
  /// Free-text brewer note (lot number, supplier, expiry, …).
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, nameNormalized, detailNormalized, unitNormalized])
  @@index([category])
}

/// BJCP style-guideline range (BRE-44).
///
/// Each row holds the canonical vital-statistics range for a single BJCP
/// sub-category (e.g. "21A" = American IPA). Recipe.bjcpCategory holds the
/// code; the API/presentation layer joins it against this table to flag
/// in/out-of-range values on the detail page.
///
/// `category` mirrors the Recipe-level "beer" | "mead" | "cider" | "wine"
/// vocabulary so the seed loader can sanity-check cross-references. Numeric
/// bounds are nullable: mead/cider have no IBU/SRM, so the comparison layer
/// must treat a null bound on either side as "no guideline for this metric"
/// and skip the comparison.
model BjcpStyle {
  id       String @id @default(cuid())
  /// BJCP sub-category code, e.g. "21A", "M1A", "C1".
  code     String  @unique
  /// Human-readable style name, e.g. "American IPA".
  name     String
  /// beer | mead | cider | wine — mirrors the `Recipe.category` vocabulary.
  category String  @default("beer")

  /// Original gravity range (specific gravity, e.g. 1.056–1.070).
  ogMin  Float?
  ogMax  Float?
  /// Final gravity range.
  fgMin  Float?
  fgMax  Float?
  /// IBU range (beer only; null on both sides for mead/cider/wine).
  ibuMin Float?
  ibuMax Float?
  /// SRM colour range (beer only).
  srmMin Float?
  srmMax Float?
  /// ABV percent range.
  abvMin Float?
  abvMax Float?

  /// Free-form provenance note (BJCP edition / source). Not user-facing.
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
}

/// A dynamic timeline log entry for a batch. Logs are intentionally flexible so
/// active fermentations can record gravity, pH, temperature, racking, nutrient,
/// tasting, and other events without schema churn.
model BatchLog {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  batch    Batch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId  String?

  logDate       DateTime @default(now())
  type          String   @default("note") // note | gravity | ph | temperature | racking | addition | tasting | other
  gravity       Float?
  ph            Float?
  temperatureC  Float?
  volumeLiters  Float?
  rating        Int?     @map("rating") // 1-5; only meaningful when type = "tasting"
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([batchId])
  @@index([logDate])
}
